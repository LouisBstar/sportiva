# ─── Supabase ─────────────────────────────────────────────────────────────────
# Récupère ces valeurs dans : Settings → API de ton projet Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Strava OAuth ──────────────────────────────────────────────────────────────
# Récupère ces valeurs dans : https://www.strava.com/settings/api
STRAVA_CLIENT_ID=000000
STRAVA_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── App ───────────────────────────────────────────────────────────────────────
# En développement : http://localhost:3000
# En production    : https://ton-projet.vercel.app (ou domaine custom)
NEXT_PUBLIC_APP_URL=https://ton-projet.vercel.app
